# ==============================================
# HMS - Required Environment Variables
# ==============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env or application-prod.properties
# with real credentials to version control.
# ==============================================

# ── Database ───────────────────────────────────
# Full JDBC connection string. In production use SSL-enabled URL:
# HMS_DB_URL=jdbc:mysql://<DB_HOST>:3306/hms_db?useSSL=true&serverTimezone=UTC&requireSSL=true
HMS_DB_URL=jdbc:mysql://localhost:3306/hms_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true

# Database credentials — use a dedicated 'hms_user' account, NOT root, in production
HMS_DB_USER=root
HMS_DB_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ── JWT ────────────────────────────────────────
# Must be at least 64 characters (512-bit) for HS256 in production.
# Generate one with: openssl rand -base64 64
HMS_JWT_SECRET=CHANGE_TO_A_LONG_RANDOM_SECRET_MIN_64_CHARS

# ── Mail ───────────────────────────────────────
HMS_MAIL_USER=noreply.support.hms@gmail.com
HMS_MAIL_PASSWORD=CHANGE_ME_GMAIL_APP_PASSWORD

# ── Frontend URL (used in email activation links) ──
HMS_FRONTEND_URL=https://your-domain.com

# ── Hibernate DDL (use 'validate' in production) ──
HMS_DDL_AUTO=validate
